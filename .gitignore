# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug / logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# env files (nunca commitar valores reais; o .env.example é só nomes)
.env*
!.env.example

# configuração local de ferramentas (caminhos absolutos da máquina)
.claude/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
